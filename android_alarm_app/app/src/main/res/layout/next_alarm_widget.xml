<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/next_alarm_widget_bg"
    android:gravity="center_vertical"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="NEXT SHIFT"
            android:textColor="#334155"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_author"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="門前直樹"
            android:textColor="#64748B"
            android:textSize="7sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="match_parent"
            android:layout_height="13dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="2dp"
            android:gravity="left|center_vertical"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:text="--/--"
            android:textColor="#111827"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_time"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:background="@drawable/next_alarm_flip_tile"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="--:--"
            android:textColor="#F8FAFC"
            android:textSize="32sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_label_line1"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="未有"
                android:textColor="#111827"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_label_line2"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="下一個鬧鐘"
                android:textColor="#111827"
                android:textSize="8sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
